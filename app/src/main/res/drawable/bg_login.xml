<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#2563EB"
                android:centerColor="#1D4ED8"
                android:endColor="#1E40AF"
                android:angle="0"/>

            <corners android:radius="22dp"/>

            <padding
                android:left="16dp"
                android:right="16dp"
                android:top="14dp"
                android:bottom="14dp"/>
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape android:shape="rectangle">

            <gradient
                android:startColor="#4F8DFF"
                android:centerColor="#3575F8"
                android:endColor="#2458F5"
                android:angle="0"/>

            <corners android:radius="22dp"/>

        </shape>
    </item>

</selector>